# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/apps/**/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/apps/**/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem
/apps/**/.wrangler/

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files
.env
.env.local
.dev.vars
apps/**/.env
apps/**/.env.local
apps/**/.dev.vars
!.env.example
!.env.local.example
!apps/**/.env.example
!apps/**/.env.local.example
!apps/**/.dev.vars.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
